  "keyFeatures": [
    "Microservices architecture with API gateway proxying to 5 independent services",
    "Two-factor authentication (2FA) via email OTP with JWT session tokens",
    "Role-based access control (rector, admin, profesor, alumno) with account validation workflow",
    "Campus building, classroom, professor cubicle, and room management",
    "AI-powered event scheduling with TensorFlow.js conflict resolution and priority-based displacement",
    "Indoor/outdoor navigation with turn-by-turn route instructions and geographic path data",
    "Google Routes API integration for walking directions with encoded polylines",
    "AI congestion prediction for campus routes using neural networks",
    "GeoJSON map data endpoint combining buildings and walkable paths from OpenStreetMap",
    "Admin analytics dashboard with access logs, route usage heatmaps, and user statistics"
  ],
