{
  "$schema": "https://mintlify.com/docs.json",
  "name": "AirGuide Backend API",
  "theme": "luma",
  "colors": {
    "primary": "#242c54"
  },
  "logo": {
    "light": "https://media.brand.dev/4b12abc7-b90c-4c2e-b178-3f6dc1601801.png",
    "dark": "https://media.brand.dev/4b12abc7-b90c-4c2e-b178-3f6dc1601801.png"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/luiss811/Backend-Airguide"
    }
  },
  "footer": {
    "socials": {
      "github": "https://github.com/luiss811/Backend-Airguide"
    }
  },
  "navigation": {
    "tabs": [
      {
        "tab": "Documentation",
        "groups": [
          {
            "group": "Get Started",
            "pages": ["introduction", "quickstart", "architecture"]
          },
          {
            "group": "Authentication",
            "pages": ["auth/overview", "auth/register", "auth/login", "auth/two-factor", "auth/password-reset"]
          },
          {
            "group": "Configuration",
            "pages": ["configuration/environment", "configuration/database", "configuration/deployment"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Auth Service",
            "pages": ["api/auth/login", "api/auth/verify-2fa", "api/auth/register", "api/auth/users"]
          },
          {
            "group": "Buildings Service",
            "pages": ["api/buildings/buildings", "api/buildings/rooms", "api/buildings/professors", "api/buildings/cubicles"]
          },
          {
            "group": "Events Service",
            "pages": ["api/events/events", "api/events/attendance"]
          },
          {
            "group": "Navigation Service",
            "pages": ["api/navigation/routes", "api/navigation/map", "api/navigation/congestion"]
          },
          {
            "group": "Analytics Service",
            "pages": ["api/analytics/dashboard", "api/analytics/reports"]
          }
        ]
      }
    ]
  }
}
